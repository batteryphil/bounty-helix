BEST_PER_GEN = 10
POP_SIZE = 50
MUTATION_RATE = 0.1
GENERATION_LOGS = f'{DATA_DIR}/generation_logs.jsonl'
HISTORY_LOGS = f'{DATA_DIR}/history_logs.jsonl'
CODE_REPO = 'helix-agi/helix-agi'
CODE_BRANCH = 'darwin_godel_machine'
AGENT_CODE_PATH = 'helix-agi/tools/darwin_godel_machine.py'

