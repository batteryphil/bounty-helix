    with open(GENERATION_LOGS, 'w') as f:
        f.write('')

# Initialize history logs
if not os.path.exists(HISTORY_LOGS):
    with open(HISTORY_LOGS, 'w') as f:
        f.write('')

def generate_population():
    population = []
    for _ in range(POP_SIZE):
        # Generate random code
        code_length = random.randint(50, 1000)
        code = ''.join(random.choices(string.ascii_letters + string.digits, k=code_length))
        code_hash = hashlib.sha256(code.encode()).hexdigest()
        population.append({'code': code, 'hash': code_hash})
    return population

def mutate(individual):
    # Randomly mutate code
    code_length = len(individual['code'])
    mutation_sites = random.sample(range(code_length), k=int(code_length * MUTATION_RATE))
    for site in mutation_sites:
        individual['code'] = individual['code'][:site]

